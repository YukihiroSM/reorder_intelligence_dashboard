# Root secrets for the production stack (docker-compose.prod.yml).
# Copy to .env (gitignored) on the server. Compose reads it both for ${...}
# substitution (POSTGRES_PASSWORD) and as the backend's env_file (the rest).

# Postgres password — used by the postgres container and the derived DATABASE_URL.
POSTGRES_PASSWORD=changeme

# AI advisor (Phase 7). Optional until then; the app boots without it.
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4-nano

# Optional overrides (sensible defaults if omitted):
# ALLOWED_ORIGINS=          # empty: same-origin via nginx, no CORS needed
# LOG_LEVEL=INFO
# BACKEND_PORT=8091         # host loopback port the global nginx proxies to
# WEB_PORT / WEBROOT        # see DEPLOY.md
