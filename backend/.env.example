# Copy to .env and fill in. Never commit .env (it is gitignored).

# Async SQLAlchemy URL. Uses the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://reorder:changeme@localhost:5440/reorder_intel

# OpenAI API key for the AI advisor (Phase 7).
OPENAI_API_KEY=sk-...

# LLM model id, provider-agnostic via LangChain. Change to switch models/providers.
LLM_MODEL=gpt-5.4-nano

# Comma-separated CORS origins allowed by the API.
ALLOWED_ORIGINS=http://localhost:5173

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
